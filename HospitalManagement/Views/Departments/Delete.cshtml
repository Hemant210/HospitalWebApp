@model HospitalManagement.Models.Department

@{
    ViewData["Title"] = "Decommission Department";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-triangle-exclamation fa-beat me-2"></i>Confirm Deletion
                    </h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-warning border text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Warning:</strong> Deleting this structural department record may result in cascading cleanups or orphaned state variables across doctor directories.
                    </div>

                    <p class="text-muted mb-1 text-uppercase small fw-bold">Target Decommission Profile</p>
                    <h3 class="fw-bold text-dark mb-4">@Model.DeptName</h3>

                    <div class="card bg-light p-3 border-0 rounded text-start mb-4">
                        <div class="small mb-1"><strong>Location Address:</strong> @Model.Location</div>
                        <div class="small"><strong>Assigned Head ID:</strong> @(Model.HeadDoctorId.HasValue? Model.HeadDoctorId.ToString() : "None")</div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="DepartmentId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm">
                                <i class="fa-solid fa-trash-can me-2"></i>Permanently Wipe From Database
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Cancel & Retain</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>