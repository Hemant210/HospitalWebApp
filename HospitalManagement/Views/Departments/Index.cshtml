@model IEnumerable<HospitalManagement.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-hospital-user text-primary me-2"></i>Hospital Departments
        </h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> Add New Department
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search by name or location..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-muted text-decoration-none border"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">@Html.DisplayNameFor(model => model.DeptName)</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">@Html.DisplayNameFor(model => model.Location)</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Head Doctor (ID)</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@Html.DisplayFor(modelItem => item.DeptName)</td>
                                <td>
                                    <span class="text-secondary">
                                        <i class="fa-solid fa-location-dot me-1 text-muted"></i>@Html.DisplayFor(modelItem => item.Location)
                                    </span>
                                </td>
                                <td>
                                    @if (item.HeadDoctorId.HasValue)
                                    {
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-solid fa-user-md text-primary me-1"></i>Dr. ID: @item.HeadDoctorId
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted text-uppercase small px-1">Not Assigned</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="fa-solid fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-folder-open fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching departments found.</p>
                </div>
            }
        </div>
    </div>
</div>