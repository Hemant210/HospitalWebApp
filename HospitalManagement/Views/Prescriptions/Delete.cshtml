@model HospitalManagement.Models.Prescription

@{
    ViewData["Title"] = "Void Prescription";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-ban me-2"></i>Void Official Prescription</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-danger text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Legal Warning:</strong> Voiding an RX slip removes all mapped medication dispensing items permanently. Ensure the pharmacy has not already fulfilled this order.
                    </div>

                    <h3 class="fw-bold text-dark mb-1">RX-#@Model.PrescriptionId</h3>
                    <p class="text-muted mb-4 fw-semibold">Patient: @Model.MedicalRecord?.Patient?.FirstName @Model.MedicalRecord?.Patient?.LastName</p>

                    <div class="bg-light p-3 rounded border text-start mb-4">
                        <div class="small mb-1"><strong>Doctor:</strong> Dr. @Model.Doctor?.LastName</div>
                        <div class="small"><strong>Date:</strong> @Model.PrescribedDate.ToString("dd MMM yyyy")</div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="PrescriptionId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm"><i class="fa-solid fa-trash-can me-2"></i>Void Record</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Abort</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>