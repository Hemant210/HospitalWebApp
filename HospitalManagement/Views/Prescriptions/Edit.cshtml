@model HospitalManagement.Models.Prescription

@{
    ViewData["Title"] = "Amend Prescription";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-pen-nib me-2"></i>Amend RX Details</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="PrescriptionId" />
                        <input type="hidden" asp-for="RecordId" /> <div class="form-group mb-3">
                            <label asp-for="DoctorId" class="control-label fw-bold mb-1">Prescribing Doctor</label>
                            <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorId"></select>
                            <span asp-validation-for="DoctorId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PrescribedDate" class="control-label fw-bold mb-1">Authorization Date</label>
                            <input asp-for="PrescribedDate" class="form-control" type="date" />
                            <span asp-validation-for="PrescribedDate" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Notes" class="control-label fw-bold mb-1">Clinical/Pharmacy Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold py-2"><i class="fa-solid fa-check me-2"></i>Update Slip</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}