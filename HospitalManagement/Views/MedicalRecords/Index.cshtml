@model IEnumerable<HospitalManagement.Models.MedicalRecord>
@using HospitalManagement.Auth

@{
    ViewData["Title"] = "Medical Records";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-notes-medical text-primary me-2"></i>Medical Records Directory
        </h2>
        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Doctor))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="fa-solid fa-circle-plus me-1"></i> Create New Record
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search by patient name or diagnosis..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Visit Date</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Patient Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Diagnosis</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Attending Doctor</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">@item.VisitDate.ToString("dd MMM yyyy")</td>
                                <td class="fw-bold text-primary">@item.Patient?.FirstName @item.Patient?.LastName</td>
                                <td><span class="text-truncate d-inline-block fw-medium text-dark" style="max-width: 250px;">@item.Diagnosis</span></td>
                                <td class="text-secondary">Dr. @item.Doctor?.FirstName @item.Doctor?.LastName</td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-info">
                                            <i class="fa-solid fa-folder-open me-1"></i>Details
                                        </a>
                                        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Doctor))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-secondary">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole(HospitalRoles.Admin))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.RecordId" class="btn btn-sm btn-outline-danger">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-folder-minus fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching medical records found.</p>
                </div>
            }
        </div>
    </div>
</div>