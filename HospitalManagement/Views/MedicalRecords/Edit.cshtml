@model HospitalManagement.Models.MedicalRecord

@{
    ViewData["Title"] = "Modify Medical Record";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-pen me-2"></i>Amend Clinical Record File</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="RecordId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PatientId" class="control-label fw-bold mb-1">Patient Profile Link</label>
                                <select asp-for="PatientId" class="form-select" asp-items="ViewBag.PatientId"></select>
                                <span asp-validation-for="PatientId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DoctorId" class="control-label fw-bold mb-1">Attending Clinician</label>
                                <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorId"></select>
                                <span asp-validation-for="DoctorId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="VisitDate" class="control-label fw-bold mb-1">Encounter Log Date</label>
                            <input asp-for="VisitDate" class="form-control" type="date" />
                            <span asp-validation-for="VisitDate" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Vitals" class="control-label fw-bold mb-1">Vitals Metrics Summary</label>
                            <input asp-for="Vitals" class="form-control" />
                            <span asp-validation-for="Vitals" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Diagnosis" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Diagnosis" class="form-control" />
                            <span asp-validation-for="Diagnosis" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Notes" class="control-label fw-bold mb-1">Progress Notes Narrative</label>
                            <textarea asp-for="Notes" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 text-muted" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold py-2"><i class="fa-solid fa-square-check me-2"></i>Commit Changes</button>
                            <a asp-action="Details" asp-route-id="@Model.RecordId" class="btn btn-outline-secondary btn-sm mt-1">Discard Actions</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}