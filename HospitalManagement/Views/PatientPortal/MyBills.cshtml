@model IEnumerable<HospitalManagement.Models.Bill>
@{
    ViewData["Title"] = "My Invoices";
}

<div class="container-fluid pt-4 px-4">
    <h3 class="fw-bold mb-4"><i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i>My Financial Invoices</h3>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3">Invoice Date</th>
                            <th class="py-3">Total Amount</th>
                            <th class="py-3">Paid Amount</th>
                            <th class="py-3">Balance Due</th>
                            <th class="py-3">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var balance = item.TotalAmount - item.PaidAmount;
                            <tr>
                                <td class="ps-4 fw-bold">@item.BillDate.ToString("dd MMM yyyy")</td>
                                <td>₹@item.TotalAmount.ToString("0.00")</td>
                                <td class="text-success">₹@item.PaidAmount.ToString("0.00")</td>
                                <td class="text-danger fw-bold">₹@balance.ToString("0.00")</td>
                                <td>
                                    @if (item.PaymentStatus == HospitalManagement.Models.PaymentStatus.Paid)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Paid</span>
                                    }
                                    else if (item.PaymentStatus == HospitalManagement.Models.PaymentStatus.Partial)
                                    {
                                        <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1">Partial</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">Unpaid</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">No invoices found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>