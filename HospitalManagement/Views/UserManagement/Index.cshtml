@model IEnumerable<HospitalManagement.Models.AppUser>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-users-gear me-2"></i>User Management</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold"><i class="fa-solid fa-user-plus me-2"></i>Add New Staff</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>System Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.FullName</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge bg-secondary">@item.Role</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success"><i class="fa-solid fa-check-circle me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fa-solid fa-ban me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <form asp-action="ToggleActiveStatus" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                            @(item.IsActive ? "Deactivate Account" : "Activate Account")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-4">
                    <p>No users found in the system.</p>
                </div>
            }
        </div>
    </div>
</div>