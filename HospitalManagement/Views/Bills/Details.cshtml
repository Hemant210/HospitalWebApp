@model HospitalManagement.Models.Bill

@{
    ViewData["Title"] = "Invoice #" + Model.BillId;
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-end mb-3 d-print-none">
                <a asp-action="Index" class="btn btn-outline-secondary me-2">Back to List</a>
                <button onclick="window.print()" class="btn btn-primary"><i class="fa-solid fa-print"></i> Print Invoice</button>
            </div>

            <div class="card shadow-sm border-0" id="invoice-card">
                <div class="card-body p-5">

                    <div class="row mb-4 border-bottom pb-3">
                        <div class="col-sm-6">
                            <h2 class="text-primary fw-bold">City Care Hospital</h2>
                            <p class="text-muted mb-0">123 Health Avenue, Medical District</p>
                            <p class="text-muted">Phone: (555) 123-4567 | Email: billing@citycare.com</p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            <h4 class="text-uppercase fw-bold text-muted">Invoice</h4>
                            <p class="mb-0"><strong>Bill No:</strong> #@Model.BillId</p>
                            <p class="mb-0"><strong>Date:</strong> @Model.BillDate.ToString("dd MMM yyyy")</p>
                            <span class="badge @(Model.PaymentStatus.ToString() == "Paid" ? "bg-success" : "bg-danger") mt-2 fs-6">
                                @Model.PaymentStatus
                            </span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-6">
                            <h6 class="text-muted text-uppercase fw-bold">Billed To:</h6>
                            <h5 class="fw-bold">@Model.Patient?.FirstName @Model.Patient?.LastName</h5>
                            <p class="mb-0"><strong>Phone:</strong> @Model.Patient?.Phone</p>
                            <p class="mb-0"><strong>Email:</strong> @Model.Patient?.Email</p>
                        </div>
                        <div class="col-sm-6 text-sm-end">
                            @if (Model.AdmissionId != null)
                            {
                                <p class="mb-0"><strong>Admission ID:</strong> @Model.AdmissionId</p>
                            }
                            @if (Model.AppointmentId != null)
                            {
                                <p class="mb-0"><strong>Appointment ID:</strong> @Model.AppointmentId</p>
                            }
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-uppercase">Description</th>
                                    <th class="text-end text-uppercase">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Doctor Consultation Fee</td>
                                    <td class="text-end">₹@Model.DoctorFee.ToString("0.00")</td>
                                </tr>
                                @if (Model.RoomCharges > 0)
                                {
                                    <tr>
                                        <td>Inpatient Room/Bed Charges</td>
                                        <td class="text-end">₹@Model.RoomCharges.ToString("0.00")</td>
                                    </tr>
                                }
                                @if (Model.LabCharges > 0)
                                {
                                    <tr>
                                        <td>Laboratory Tests</td>
                                        <td class="text-end">₹@Model.LabCharges.ToString("0.00")</td>
                                    </tr>
                                }
                                @if (Model.MedicineCharges > 0)
                                {
                                    <tr>
                                        <td>Pharmacy & Medicines</td>
                                        <td class="text-end">₹@Model.MedicineCharges.ToString("0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row justify-content-end">
                        <div class="col-sm-5">
                            <table class="table table-sm table-borderless">
                                <tr>
                                    <th>Subtotal:</th>
                                    <td class="text-end">₹@((Model.DoctorFee + Model.RoomCharges + Model.LabCharges + Model.MedicineCharges).ToString("0.00"))</td>
                                </tr>
                                @if (Model.Discount > 0)
                                {
                                    <tr class="text-success">
                                        <th>Discount:</th>
                                        <td class="text-end">-₹@Model.Discount.ToString("0.00")</td>
                                    </tr>
                                }
                                <tr class="border-top border-bottom fs-5">
                                    <th>Net Total:</th>
                                    <td class="text-end fw-bold text-primary">₹@Model.TotalAmount.ToString("0.00")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Paid Amount:</th>
                                    <td class="text-end text-muted">₹@Model.PaidAmount.ToString("0.00")</td>
                                </tr>
                                <tr class="text-danger border-top">
                                    <th>Amount Due:</th>
                                    <td class="text-end fw-bold">₹@((Model.TotalAmount - Model.PaidAmount).ToString("0.00"))</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="text-center mt-5 d-print-none text-muted">
                        <small>This is a computer-generated invoice and does not require a physical signature.</small>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    @@media print {
        body * {
            visibility: hidden;
        }

        #invoice-card, #invoice-card * {
            visibility: visible;
        }

        #invoice-card {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            box-shadow: none !important;
            border: none !important;
        }

        .d-print-none {
            display: none !important;
        }
    }
</style>