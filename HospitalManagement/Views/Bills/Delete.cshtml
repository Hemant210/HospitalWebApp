@model HospitalManagement.Models.Bill

@{
    ViewData["Title"] = "Void Invoice";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-ban me-2"></i>Void Financial Invoice</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-danger text-start small mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-1"></i>
                        <strong>Legal Compliance Warning:</strong> Voiding a financial ledger record completely drops the invoice from revenue reporting. Ensure any collected payments are refunded prior to executing this void.
                    </div>

                    <p class="text-muted mb-1 text-uppercase small fw-bold">Target Void Invoice</p>
                    <h3 class="fw-bold text-dark mb-1">INV-#@Model.BillId</h3>
                    <p class="text-muted mb-4 fw-semibold">Patient Account: @Model.Patient?.FirstName @Model.Patient?.LastName</p>

                    <div class="bg-light p-3 rounded border text-start mb-4">
                        <div class="row">
                            <div class="col-6 small"><strong>Net Total:</strong> ₹@Model.TotalAmount.ToString("N2")</div>
                            <div class="col-6 small"><strong>Status:</strong> @Model.PaymentStatus</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="BillId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm"><i class="fa-solid fa-trash-can me-2"></i>Void & Destroy Record</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Abort Action</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>