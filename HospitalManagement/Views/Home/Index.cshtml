@{
    ViewData["Title"] = "Dashboard Overview";
}

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%);
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%);
    }

    .bg-gradient-danger {
        background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%);
    }

    .hover-elevate {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .hover-elevate:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }

    .icon-circle {
        height: 3rem;
        width: 3rem;
        border-radius: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(255, 255, 255, 0.2);
    }

    .article-img-placeholder {
        width: 110px;
        height: 110px;
        object-fit: cover;
    }
</style>

<div class="container-fluid pt-4 px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Hospital Command Center</h2>
            <p class="text-muted small mb-0">System Overview & Updates</p>
        </div>
        <div>
            <span class="text-muted fw-bold"><i class="fa-regular fa-clock me-1"></i>@DateTime.Now.ToString("dd MMMM yyyy, dddd")</span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card bg-gradient-primary text-white border-0 shadow-sm hover-elevate h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-uppercase fw-bold mb-1 text-white-50 small">Total Patients</p>
                            <h2 class="display-6 fw-bold mb-0">@(ViewBag.TotalPatients ?? "0")</h2>
                        </div>
                        <div class="icon-circle">
                            <i class="fa-solid fa-hospital-user fs-4 text-white"></i>
                        </div>
                    </div>
                </div>
                <a asp-controller="Patients" asp-action="Index" class="card-footer d-flex align-items-center justify-content-between border-top-0 text-white text-decoration-none" style="background-color: rgba(0,0,0,0.1);">
                    <span class="small fw-bold">View Directory</span>
                    <i class="fas fa-angle-right"></i>
                </a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card bg-gradient-success text-white border-0 shadow-sm hover-elevate h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-uppercase fw-bold mb-1 text-white-50 small">Available Beds</p>
                            <h2 class="display-6 fw-bold mb-0">@(ViewBag.AvailableBeds ?? "0")</h2>
                        </div>
                        <div class="icon-circle">
                            <i class="fa-solid fa-bed-pulse fs-4 text-white"></i>
                        </div>
                    </div>
                </div>
                <a asp-controller="Beds" asp-action="Index" class="card-footer d-flex align-items-center justify-content-between border-top-0 text-white text-decoration-none" style="background-color: rgba(0,0,0,0.1);">
                    <span class="small fw-bold">Manage Wards</span>
                    <i class="fas fa-angle-right"></i>
                </a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card bg-gradient-warning text-dark border-0 shadow-sm hover-elevate h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-uppercase fw-bold mb-1 text-dark-50 small" style="opacity: 0.7;">Appointments Today</p>
                            <h2 class="display-6 fw-bold mb-0">@(ViewBag.TodaysAppointments ?? "0")</h2>
                        </div>
                        <div class="icon-circle" style="background-color: rgba(255,255,255,0.4);">
                            <i class="fa-regular fa-calendar-check fs-4 text-dark"></i>
                        </div>
                    </div>
                </div>
                <a asp-controller="Appointments" asp-action="Index" class="card-footer d-flex align-items-center justify-content-between border-top-0 text-dark text-decoration-none" style="background-color: rgba(0,0,0,0.05);">
                    <span class="small fw-bold">View Schedule</span>
                    <i class="fas fa-angle-right"></i>
                </a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card bg-gradient-danger text-white border-0 shadow-sm hover-elevate h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-uppercase fw-bold mb-1 text-white-50 small">Pending Lab Tests</p>
                            <h2 class="display-6 fw-bold mb-0">@(ViewBag.PendingLabs ?? "0")</h2>
                        </div>
                        <div class="icon-circle">
                            <i class="fa-solid fa-microscope fs-4 text-white"></i>
                        </div>
                    </div>
                </div>
                <a asp-controller="LabTests" asp-action="Index" class="card-footer d-flex align-items-center justify-content-between border-top-0 text-white text-decoration-none" style="background-color: rgba(0,0,0,0.1);">
                    <span class="small fw-bold">Process Labs</span>
                    <i class="fas fa-angle-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fa-regular fa-newspaper me-2"></i>Hospital Updates & Health Articles</h6>
                    <span class="badge bg-primary-subtle text-primary">Latest News</span>
                </div>
                <div class="card-body p-4 pt-0">

                    <div class="d-flex mb-4 pb-4 border-bottom">
                        <div class="flex-shrink-0 bg-light rounded d-flex align-items-center justify-content-center article-img-placeholder border">
                            <i class="fa-solid fa-heart-pulse text-danger fs-1"></i>
                        </div>
                        <div class="ms-3">
                            <span class="badge bg-danger-subtle text-danger mb-2 px-2 py-1"><i class="fa-solid fa-star me-1"></i>Cardiology</span>
                            <h5 class="fw-bold mb-1 text-dark">New Advanced Cardiac Care Wing Opens</h5>
                            <p class="text-muted small mb-2">City Care Hospital is proud to introduce our state-of-the-art cardiovascular imaging and robotic surgery capabilities, drastically reducing recovery times for our patients.</p>
                            <a href="#" class="text-decoration-none small fw-bold">Read Full Article &rarr;</a>
                        </div>
                    </div>

                    <div class="d-flex mb-4 pb-4 border-bottom">
                        <div class="flex-shrink-0 bg-light rounded d-flex align-items-center justify-content-center article-img-placeholder border">
                            <i class="fa-solid fa-virus-covid text-success fs-1"></i>
                        </div>
                        <div class="ms-3">
                            <span class="badge bg-success-subtle text-success mb-2 px-2 py-1"><i class="fa-solid fa-shield-virus me-1"></i>Public Health</span>
                            <h5 class="fw-bold mb-1 text-dark">Seasonal Flu Prevention Guidelines</h5>
                            <p class="text-muted small mb-2">As the seasons change, our Chief Medical Officer outlines the best practices for immunity boosting and when to schedule your family's annual vaccination appointments.</p>
                            <a href="#" class="text-decoration-none small fw-bold">Read Full Article &rarr;</a>
                        </div>
                    </div>

                    <div class="d-flex">
                        <div class="flex-shrink-0 bg-light rounded d-flex align-items-center justify-content-center article-img-placeholder border">
                            <i class="fa-solid fa-staff-snake text-info fs-1"></i>
                        </div>
                        <div class="ms-3">
                            <span class="badge bg-info-subtle text-info-emphasis mb-2 px-2 py-1"><i class="fa-solid fa-award me-1"></i>Milestone</span>
                            <h5 class="fw-bold mb-1 text-dark">Hospital Achieves Tier-1 Accreditation</h5>
                            <p class="text-muted small mb-2">Thanks to the tireless work of our dedicated medical staff and administrative team, we have been awarded the highest national standard for patient care and clinical excellence.</p>
                            <a href="#" class="text-decoration-none small fw-bold">Read Full Article &rarr;</a>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 border-start border-info border-4 h-100">
                <div class="card-header bg-white py-3 border-bottom pb-2">
                    <h6 class="m-0 fw-bold text-dark"><i class="fa-solid fa-user-doctor me-2 text-info"></i>On-Duty Specialists</h6>
                    <p class="text-muted small mb-0 mt-1">Leading practitioners available today.</p>
                </div>
                <div class="list-group list-group-flush">
                    @if (ViewBag.AvailableDoctors != null && ((IEnumerable<HospitalManagement.Models.Doctor>)ViewBag.AvailableDoctors).Any())
                    {
                        foreach (var doctor in (IEnumerable<HospitalManagement.Models.Doctor>)ViewBag.AvailableDoctors)
                        {
                            <div class="list-group-item px-4 py-3 d-flex align-items-center">
                                <div class="bg-light border text-primary rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 45px; height: 45px;">
                                    <i class="fa-solid fa-user-md fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold text-dark mb-0">Dr. @doctor.FirstName @doctor.LastName</h6>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <span class="badge bg-info-subtle text-info-emphasis px-2 py-1" style="font-size: 0.7rem;">@doctor.Specialization</span>
                                        <small class="text-muted" style="font-size: 0.75rem;"><i class="fa-solid fa-building me-1"></i>@(doctor.Department?.DeptName ?? "General")</small>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="card-body p-3 text-center bg-light mt-auto border-top">
                            <a asp-controller="Doctors" asp-action="Index" class="btn btn-sm btn-outline-info fw-bold w-100">View Full Directory</a>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <i class="fa-solid fa-user-slash fs-2 mb-2 text-light"></i>
                            <p class="mb-0 small">No specialist data found in the directory.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>