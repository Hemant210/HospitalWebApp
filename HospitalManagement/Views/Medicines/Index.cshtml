@model IEnumerable<HospitalManagement.Models.Medicine>
@using HospitalManagement.Auth

@{
    ViewData["Title"] = "Pharmacy Inventory";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-pills text-primary me-2"></i>Pharmacy Stock Inventory
        </h2>
        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Pharmacist))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="fa-solid fa-plus-circle me-1"></i> Add New Drug
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search drug name or category type..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Medicine Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Category</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Stock Level</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Unit Price</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@Html.DisplayFor(modelItem => item.Name)</td>
                                <td>
                                    <span class="badge bg-light text-dark border px-2 py-1.5 rounded">
                                        <i class="fa-solid fa-tags text-muted me-1"></i>@Html.DisplayFor(modelItem => item.Category)
                                    </span>
                                </td>
                                <td>
                                    @if (item.StockQty <= 10)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 rounded fw-bold">
                                            <i class="fa-solid fa-triangle-exclamation fa-fade me-1"></i>@item.StockQty Left (Low Stock)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-dark fw-semibold">@item.StockQty Units</span>
                                    }
                                </td>
                                <td class="fw-semibold text-dark">₹@item.UnitPrice.ToString("N2")</td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.MedicineId" class="btn btn-sm btn-outline-info" title="Detailed Overview">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Pharmacist))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.MedicineId" class="btn btn-sm btn-outline-secondary" title="Update Stock">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MedicineId" class="btn btn-sm btn-outline-danger" title="Remove Item">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-box-open fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching pharmaceutical inventory listings found.</p>
                </div>
            }
        </div>
    </div>
</div>