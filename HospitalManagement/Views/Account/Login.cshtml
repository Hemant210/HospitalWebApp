@model HospitalManagement.ViewModels.LoginViewModel

@{
    Layout = null; // CRITICAL: Drops the sidebar/navbar for a clean auth screen
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secure Access - City Care Hospital</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body, html {
            height: 100%;
            background-color: #f8f9fa;
        }

        .login-sidebar {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            text-align: center;
        }

        .demo-chip {
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .demo-chip:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            }
    </style>
</head>
<body>

    <div class="container-fluid h-100">
        <div class="row h-100">
            <div class="col-lg-5 col-md-6 login-sidebar d-none d-md-flex">
                <div class="mb-4">
                    <i class="fa-solid fa-hospital-user" style="font-size: 5rem;"></i>
                </div>
                <h1 class="fw-bold mb-3">City Care Hospital</h1>
                <p class="lead text-white-50">Enterprise Resource & Clinical Management System</p>

                <div class="mt-5 border-top border-light pt-4 w-75" style="opacity: 0.8;">
                    <p class="small mb-0"><i class="fa-solid fa-shield-halved me-2"></i>Authorized Personnel Only</p>
                </div>
            </div>

            <div class="col-lg-7 col-md-6 d-flex align-items-center justify-content-center">
                <div class="w-100" style="max-width: 450px; padding: 2rem;">

                    <div class="d-md-none text-center mb-5 text-primary">
                        <i class="fa-solid fa-hospital-user fs-1 mb-2"></i>
                        <h2 class="fw-bold">City Care Hospital</h2>
                    </div>

                    <div class="mb-4">
                        <h3 class="fw-bold text-dark">Welcome Back</h3>
                        <p class="text-muted">Please sign in to your account.</p>
                    </div>

                    <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded border-danger border-start border-4 small py-2"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="EmailOrPhone" class="form-control" id="floatingInput" placeholder="name@example.com or 9998887777" />
                            <label asp-for="EmailOrPhone">Email address or Phone Number</label>
                            <span asp-validation-for="EmailOrPhone" class="text-danger fs-7"></span>
                        </div>

                        <div class="form-floating mb-3 shadow-sm">
                            <input asp-for="Password" class="form-control" id="floatingPassword" placeholder="Password" />
                            <label for="floatingPassword"><i class="fa-solid fa-lock text-muted me-2"></i>Password</label>
                            <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                                <label class="form-check-label text-muted small" for="rememberMe">Remember me</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mb-5">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm py-3">
                                Secure Login <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
                            </button>
                        </div>
                    </form>

                    <div class="mt-4 border-top pt-4">
                        <p class="text-muted small fw-bold text-uppercase mb-3">Quick Demo Access</p>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 demo-chip" onclick="fillDemo('admin@hospital.com', 'Admin@123')">
                                <i class="fa-solid fa-user-shield me-1"></i> Admin
                            </span>
                            <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-3 py-2 demo-chip" onclick="fillDemo('doctor@hospital.com', 'Doctor@123')">
                                <i class="fa-solid fa-user-doctor me-1"></i> Doctor
                            </span>
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 demo-chip" onclick="fillDemo('reception@hospital.com', 'Reception@123')">
                                <i class="fa-solid fa-desktop me-1"></i> Front Desk
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        function fillDemo(email, password) {
            document.getElementById('floatingInput').value = email;
            document.getElementById('floatingPassword').value = password;
        }
    </script>
</body>
</html>