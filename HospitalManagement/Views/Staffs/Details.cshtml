@model HospitalManagement.Models.Staff

@{
    ViewData["Title"] = "Staff Specifications";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-address-card me-2"></i>Personnel Profile File</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-placeholder d-inline-flex bg-light text-primary rounded-circle align-items-center justify-content-center border" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-user-tie fs-2"></i>
                        </div>
                        <h4 class="fw-bold mt-2 mb-0 text-dark">@Model.FirstName @Model.LastName</h4>
                        <span class="text-muted small">System File ID: #@Model.StaffId</span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Assigned Role</div>
                        <div class="col-sm-8 text-dark fw-bold">@Model.Role</div>
                    </div>
                    <hr class="text-muted my-2" />
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Department Branch</div>
                        <div class="col-sm-8 text-secondary">@Model.Department?.DeptName</div>
                    </div>
                    <hr class="text-muted my-2" />
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Contact Line</div>
                        <div class="col-sm-8 text-dark">
                            <i class="fa-solid fa-phone me-1 text-muted"></i>@(string.IsNullOrEmpty(Model.Phone) ? "Unconfigured Line" : Model.Phone)
                        </div>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="row g-2">
                        <div class="col-6">
                            <a asp-action="Edit" asp-route-id="@Model.StaffId" class="btn btn-primary fw-bold w-100 py-2"><i class="fa-solid fa-user-pen me-2"></i>Modify Profile</a>
                        </div>
                        <div class="col-6">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">Return to Directory</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>