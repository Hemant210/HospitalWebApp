@model IEnumerable<HospitalManagement.Models.Staff>

@{
    ViewData["Title"] = "Staff Directory";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-users-gear text-primary me-2"></i>Staff Directory
        </h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
            <i class="fa-solid fa-user-plus me-1"></i> Add New Staff
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search by name or role designation..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-muted border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Full Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Role / Designation</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Assigned Department</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Contact Info</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.FirstName @item.LastName</td>
                                <td>
                                    <span class="badge bg-secondary px-2 py-1.5"><i class="fa-solid fa-id-badge me-1"></i>@item.Role</span>
                                </td>
                                <td class="text-secondary fw-medium">
                                    <i class="fa-solid fa-building me-1 text-muted small"></i>@(item.Department?.DeptName ?? "Unassigned")
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Phone))
                                    {
                                        <span class="small text-muted"><i class="fa-solid fa-phone me-1 text-light-muted"></i>@item.Phone</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted italic small">No record</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.StaffId" class="btn btn-sm btn-outline-secondary" title="Edit Properties"><i class="fa-solid fa-user-pen"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.StaffId" class="btn btn-sm btn-outline-info" title="Detailed View"><i class="fa-solid fa-eye"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.StaffId" class="btn btn-sm btn-outline-danger" title="Terminate File"><i class="fa-solid fa-user-slash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-users-slash fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching staff configuration parameters found.</p>
                </div>
            }
        </div>
    </div>
</div>