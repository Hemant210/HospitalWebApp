    <!-- Lab Tests: Medical team only -->
    @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Doctor)
        || User.IsInRole(HospitalRoles.Nurse) || User.IsInRole(HospitalRoles.LabTechnician))
