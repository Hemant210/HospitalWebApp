    {
        <li class="nav-item">
            <a class="nav-link-s" asp-controller="Medicines" asp-action="Index">
                <div class="nav-icon"><i class="fa-solid fa-pills"></i></div>
                <span class="nav-text">Medicines</span>
            </a>
        </li>
