    {
        <li class="nav-item">
            <a class="nav-link-s" asp-controller="Bills" asp-action="Index">
                <div class="nav-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                <span class="nav-text">Billing</span>
            </a>
