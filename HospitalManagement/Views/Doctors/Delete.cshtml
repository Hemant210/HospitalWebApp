@model HospitalManagement.Models.Doctor

@{
    ViewData["Title"] = "Decommission Doctor Record";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>Confirm Account Removal
                    </h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-warning border text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Critical Cascade Restriction Warning:</strong> Removing this doctor profile stops them from managing active appointment workflows or clinical medical files.
                    </div>

                    <p class="text-muted mb-1 text-uppercase small fw-bold">Target Practitioner File</p>
                    <h3 class="fw-bold text-dark mb-4">Dr. @Model.FirstName @Model.LastName</h3>

                    <div class="card bg-light p-3 border-0 rounded text-start mb-4">
                        <div class="small mb-1"><strong>Specialization Segment:</strong> @Model.Specialization</div>
                        <div class="small"><strong>Bound Organizational Wing:</strong> @Model.Department?.DeptName</div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="DoctorId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm">
                                <i class="fa-solid fa-user-slash me-2"></i>Confirm Drop Action
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Retain Practitioner Profile</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>