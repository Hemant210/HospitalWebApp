@model IEnumerable<HospitalManagement.Models.Doctor>

@{
    ViewData["Title"] = "Doctors Directory";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-user-md text-primary me-2"></i>Doctors Directory
        </h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="fa-solid fa-user-plus me-1"></i> Add New Doctor
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search by name or specialization..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Doctor Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Specialization</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Department</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Contact Info</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">Dr. @item.FirstName @item.LastName</td>
                                <td>
                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle px-2.5 py-1.5 rounded-pill fw-bold">
                                        <i class="fa-solid fa-stethoscope me-1"></i>@Html.DisplayFor(modelItem => item.Specialization)
                                    </span>
                                </td>
                                <td class="text-secondary fw-medium">
                                    <i class="fa-solid fa-building me-1 text-muted small"></i>@(item.Department?.DeptName ?? "Unassigned")
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-1 small text-muted">
                                        @if (!string.IsNullOrEmpty(item.Phone))
                                        {
                                            <span><i class="fa-solid fa-phone me-1 text-light-muted"></i>@item.Phone</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Email))
                                        {
                                            <span><i class="fa-solid fa-envelope me-1 text-light-muted"></i>@item.Email</span>
                                        }
                                    </div>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.DoctorId" class="btn btn-sm btn-outline-info" title="View Details">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.DoctorId" class="btn btn-sm btn-outline-secondary" title="Edit Profile">
                                                <i class="fa-solid fa-user-pen"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.DoctorId" class="btn btn-sm btn-outline-danger" title="Remove Record">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-user-doctor fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching medical practitioners found.</p>
                </div>
            }
        </div>
    </div>
</div>