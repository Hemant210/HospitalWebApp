@model HospitalManagement.Models.Doctor

@{
    ViewData["Title"] = "Doctor Specifications";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-id-card me-2"></i>Practitioner Profile File</h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-placeholder d-inline-flex bg-light text-primary rounded-circle align-items-center justify-content-center border" style="width: 75px; height: 75px;">
                            <i class="fa-solid fa-user-md fs-1"></i>
                        </div>
                        <h4 class="fw-bold mt-2 mb-0 text-dark">Dr. @Model.FirstName @Model.LastName</h4>
                        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle mt-1 px-3 py-1 rounded-pill">
                            @Model.Specialization
                        </span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Department</div>
                        <div class="col-sm-8 text-dark fw-semibold">
                            <i class="fa-solid fa-building me-1 text-muted"></i>@(Model.Department?.DeptName ?? "Unassigned Division")
                        </div>
                    </div>
                    <hr class="text-muted my-2" />
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Phone Extension</div>
                        <div class="col-sm-8 text-secondary">
                            <i class="fa-solid fa-phone me-1 text-muted"></i>@(string.IsNullOrEmpty(Model.Phone) ? "No Connected Line" : Model.Phone)
                        </div>
                    </div>
                    <hr class="text-muted my-2" />
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted fw-bold text-uppercase small">Secure Mail</div>
                        <div class="col-sm-8 text-dark">
                            <i class="fa-solid fa-envelope me-1 text-muted"></i>@(string.IsNullOrEmpty(Model.Email) ? "No Linked Email Address" : Model.Email)
                        </div>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="row g-2">
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="col-6">
                                <a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-primary fw-bold w-100 py-2">
                                    <i class="fa-solid fa-user-pen me-2"></i>Modify Profile
                                </a>
                            </div>
                        }
                        <div class="col-(User.IsInRole(" Admin") ? 6 : 12)">
                            <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">
                                <i class="fa-solid fa-arrow-left me-1"></i>Back to Directory
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>