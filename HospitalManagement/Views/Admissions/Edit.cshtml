@model HospitalManagement.Models.Admission

@{
    ViewData["Title"] = "Process Patient Discharge";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-right-from-bracket me-2"></i>Update Case / Process Discharge</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="AdmissionId" />

                        <div class="row mb-3 bg-light p-3 rounded border mx-0 g-2">
                            <div class="col-md-6">
                                <span class="d-block small text-muted text-uppercase fw-bold">Active Patient File:</span>
                                <select asp-for="PatientId" class="form-select bg-white mt-1" asp-items="ViewBag.PatientId" readonly></select>
                            </div>
                            <div class="col-md-6">
                                <span class="d-block small text-muted text-uppercase fw-bold">Bed Allocation Asset:</span>
                                <select asp-for="BedId" class="form-select bg-white mt-1" asp-items="ViewBag.BedId"></select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DoctorId" class="control-label fw-bold mb-1">Attending Physician Authority</label>
                                <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.DoctorId"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="AdmitDate" class="control-label fw-bold mb-1">Admission Check-In Date</label>
                                <input asp-for="AdmitDate" class="form-control" type="datetime-local" readonly tabindex="-1" />
                            </div>
                        </div>

                        <div class="form-group mb-3 p-3 bg-warning-subtle border border-warning rounded">
                            <label asp-for="DischargeDate" class="control-label fw-bold text-warning-emphasis mb-1"><i class="fa-solid fa-calendar-day me-1"></i>Execute Discharge Clock Stamp</label>
                            <input asp-for="DischargeDate" class="form-control bg-white" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            <small class="text-muted d-block mt-1">Stamping this value frees up the assigned bed allocation resource for incoming patients instantly upon database sync.</small>
                            <span asp-validation-for="DischargeDate" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Reason" class="control-label fw-bold mb-1">Clinical Remarks / Diagnosis Updates</label>
                            <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Reason" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 text-muted" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold py-2 text-dark"><i class="fa-solid fa-right-to-bracket me-2"></i>Apply Changes & Stamp Database</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Cancel Action</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}