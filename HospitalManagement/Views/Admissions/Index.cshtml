@model IEnumerable<HospitalManagement.Models.Admission>

@{
    ViewData["Title"] = "Inpatient Admissions";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-bed-pulse text-primary me-2"></i>Inpatient Admissions Log
        </h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
            <i class="fa-solid fa-procedures me-1"></i> Admit New Patient
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search Patient, Doctor, or Reason..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Patient Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Admission Date</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Allotted Bed</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Attending Doctor</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Discharge Status</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark fs-6">@item.Patient?.FirstName @item.Patient?.LastName</td>
                                <td class="fw-medium text-secondary">@item.AdmitDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                <td>
                                    <span class="badge bg-light text-primary border border-primary-subtle px-2 py-1.5 fw-semibold">
                                        <i class="fa-solid fa-door-open me-1 text-muted"></i>@(item.Bed?.Ward?.WardName) - Bed @item.Bed?.BedNumber
                                    </span>
                                </td>
                                <td class="text-dark fw-medium">Dr. @item.Doctor?.LastName</td>
                                <td>
                                    @if (item.DischargeDate.HasValue)
                                    {
                                        <div class="d-flex flex-column">
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 fw-bold align-self-start mb-1">
                                                <i class="fa-solid fa-house-medical me-1"></i>Discharged
                                            </span>
                                            <small class="text-muted border-start ps-1" style="font-size:0.75rem;">@item.DischargeDate.Value.ToString("dd MMM yy")</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1 fw-bold">
                                            <i class="fa-solid fa-hospital-user me-1 fa-pulse"></i>Active Inpatient
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-inline-flex gap-1 align-items-center">
                                        @if (item.DischargeDate != null)
                                        {
                                            <a asp-controller="Bills" asp-action="GenerateFromAdmission" asp-route-id="@item.AdmissionId" class="btn btn-xs btn-success fw-bold shadow-sm">
                                                <i class="fa-solid fa-file-invoice-dollar me-1"></i>Invoice Bill
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.AdmissionId" class="btn btn-xs btn-outline-warning fw-bold shadow-sm">
                                                <i class="fa-solid fa-right-from-bracket me-1"></i>Discharge
                                            </a>
                                        }

                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.AdmissionId" class="btn btn-sm btn-outline-info" title="View Case Record"><i class="fa-solid fa-eye"></i></a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.AdmissionId" class="btn btn-sm btn-outline-danger" title="Purge Record"><i class="fa-solid fa-trash"></i></a>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-circle-nodes fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No active or historic inpatient admission instances tracked.</p>
                </div>
            }
        </div>
    </div>
</div>