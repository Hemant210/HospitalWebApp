@model HospitalManagement.Models.Admission

@{
    ViewData["Title"] = "Purge Admission Record";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Confirm Structural Database Removal</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-danger text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Critical Notice:</strong> Dropping this structural admission profile completely cancels any open invoicing ledger streams inside child billing databases.
                    </div>

                    <p class="text-muted mb-1 text-uppercase small fw-bold">Target Inpatient Case Profile</p>
                    <h3 class="fw-bold text-dark mb-1">@Model.Patient?.FirstName @Model.Patient?.LastName</h3>
                    <span class="text-muted small">Admission Log Sequence reference: #@Model.AdmissionId</span>

                    <div class="card bg-light p-3 border-0 rounded text-start my-4 gap-1">
                        <div class="small"><strong>Attending Doctor:</strong> Dr. @Model.Doctor?.LastName</div>
                        <div class="small"><strong>Bed Asset Release Hook:</strong> Wing @Model.Bed?.Ward?.WardName - Bed @Model.Bed?.BedNumber</div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="AdmissionId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm"><i class="fa-solid fa-dumpster-fire me-2"></i>Permanently Wipe Record</button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Retain Configuration Profile</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>