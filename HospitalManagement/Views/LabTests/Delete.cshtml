@model HospitalManagement.Models.LabTest

@{
    ViewData["Title"] = "Cancel Lab Order";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Cancel & Delete Lab Order</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-danger text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Administrative Warning:</strong> Deleting this lab test order will remove it permanently from the patient's medical history and billing pipeline. If the test was already paid for, ensure a refund is processed.
                    </div>

                    <h4 class="fw-bold text-dark mb-1">@Model.TestName</h4>
                    <p class="text-muted mb-4">Patient: @Model.Patient?.FirstName @Model.Patient?.LastName</p>

                    <div class="bg-light p-3 rounded border text-start mb-4">
                        <div class="row">
                            <div class="col-6 small"><strong>Status:</strong> @Model.Status</div>
                            <div class="col-6 small"><strong>Billed Cost:</strong> ₹@Model.Cost</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="TestId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm">
                                <i class="fa-solid fa-trash-can me-2"></i>Confirm Deletion
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Abort Deletion</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>