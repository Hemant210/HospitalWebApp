@model IEnumerable<HospitalManagement.Models.Appointment>
@using HospitalManagement.Auth

@{
    ViewData["Title"] = "Appointments Scheduling";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-calendar-check text-primary me-2"></i>Encounter Scheduling Queue
        </h2>
        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Receptionist))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="fa-solid fa-calendar-plus me-1"></i> Book Appointment
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search Patient, Doctor, or Status..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">Schedule Date/Time</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Patient Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Assigned Doctor</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Reason / Purpose</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Status</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="fa-regular fa-clock me-1 text-primary small"></i>@item.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")
                                </td>
                                <td class="fw-semibold text-primary">@item.Patient?.FirstName @item.Patient?.LastName</td>
                                <td class="text-secondary fw-medium">Dr. @item.Doctor?.FirstName @item.Doctor?.LastName</td>
                                <td><span class="text-truncate d-inline-block text-muted small" style="max-width: 180px;">@item.Reason</span></td>
                                <td>
                                    @if (item.Status.ToString() == "Scheduled" || item.Status.ToString() == "Available")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2.5 py-1.5 rounded-pill fw-bold">Scheduled</span>
                                    }
                                    else if (item.Status.ToString() == "Completed")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 rounded-pill fw-bold">Completed</span>
                                    }
                                    else // Cancelled or Maintenance / No-show
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1.5 rounded-pill fw-bold">@item.Status</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-info" title="View Specifics"><i class="fa-solid fa-eye"></i></a>
                                        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Receptionist))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-secondary" title="Reschedule"><i class="fa-solid fa-calendar-days"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-danger" title="Cancel Booking"><i class="fa-solid fa-calendar-xmark"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-calendar-minus fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching tracking allocations booked inside timeframe index tables.</p>
                </div>
            }
        </div>
    </div>
</div>