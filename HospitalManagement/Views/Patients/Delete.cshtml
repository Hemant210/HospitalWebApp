@model HospitalManagement.Models.Patient

@{
    ViewData["Title"] = "Purge Patient Record";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-danger border-2">
                <div class="card-header bg-danger text-white py-3 text-center shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i>Confirm Master Purge</h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="alert alert-danger text-start small mb-4">
                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                        <strong>Absolute Deletion Warning:</strong> Deleting the Master Patient Record will orphan or cascade-delete all linked Appointments, Admissions, Medical Histories, Prescriptions, and Invoices.
                    </div>

                    <h3 class="fw-bold text-dark mb-1">@Model.FirstName @Model.LastName</h3>
                    <p class="text-muted mb-4 fw-semibold">UHN Reference: #@Model.PatientId</p>

                    <div class="bg-light p-3 rounded border text-start mb-4">
                        <div class="row">
                            <div class="col-6 small"><strong>DOB:</strong> @(Model.DOB?.ToString("dd MMM yyyy") ?? "N/A")</div>
                            <div class="col-6 small"><strong>Phone:</strong> @(Model.Phone ?? "N/A")</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="PatientId" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger fw-bold py-2 shadow-sm">
                                <i class="fa-solid fa-trash-can me-2"></i>Purge Profile & All Data
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-1">Abort Deletion</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>