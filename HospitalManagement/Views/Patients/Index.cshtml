@model IEnumerable<HospitalManagement.Models.Patient>
@using HospitalManagement.Auth

@{
    ViewData["Title"] = "Patient Registry";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <h2 class="fw-bold text-dark m-0">
            <i class="fa-solid fa-users text-primary me-2"></i>Patient Master Registry
        </h2>
        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Receptionist))
        {
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="fa-solid fa-user-plus me-1"></i> Register New Patient
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 bg-light rounded">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-10 col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0" placeholder="Search by name or phone number..." />
                    </div>
                </div>
                <div class="col-2 col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-secondary fw-bold px-3">Filter</button>
                    @if (ViewData["CurrentFilter"] != null)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary border bg-white"><i class="fa-solid fa-xmark"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase fs-7 text-muted">UHN / ID</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Patient Name</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Contact Info</th>
                            <th class="py-3 text-uppercase fs-7 text-muted">Blood Group</th>
                            <th class="pe-4 py-3 text-end text-uppercase fs-7 text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.PatientId</td>
                                <td class="fw-bold text-dark fs-6">@item.FirstName @item.LastName</td>
                                <td>
                                    <div class="d-flex flex-column gap-1 small text-muted">
                                        @if (!string.IsNullOrEmpty(item.Phone))
                                        {
                                            <span><i class="fa-solid fa-phone me-1 text-light-muted"></i>@item.Phone</span>
                                        }
                                        else
                                        {
                                            <span class="fst-italic">No Phone Recorded</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.BloodGroup))
                                    {
                                        <span class="badge bg-danger text-white border border-danger-subtle px-2 py-1 fs-6">
                                            <i class="fa-solid fa-droplet me-1"></i>@item.BloodGroup
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Unknown</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.PatientId" class="btn btn-sm btn-outline-info" title="View Patient File">
                                            <i class="fa-solid fa-folder-open"></i> File
                                        </a>
                                        @if (User.IsInRole(HospitalRoles.Admin) || User.IsInRole(HospitalRoles.Receptionist))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.PatientId" class="btn btn-sm btn-outline-secondary" title="Update Details">
                                                <i class="fa-solid fa-user-pen"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole(HospitalRoles.Admin))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.PatientId" class="btn btn-sm btn-outline-danger" title="Purge Record">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fa-solid fa-users-slash fs-2 mb-3 text-light"></i>
                    <p class="mb-0">No matching patient profiles located in the registry.</p>
                </div>
            }
        </div>
    </div>
</div>